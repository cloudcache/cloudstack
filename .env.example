# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=quickstack
MYSQL_PASSWORD=quickstack

# ── LLDAP ─────────────────────────────────────────────────────────────────────
# LLDAP uses the same MySQL via: mysql://quickstack:$MYSQL_PASSWORD@mysql:3306/quickstack
LLDAP_JWT_SECRET=change-me-lldap-jwt-secret
LLDAP_BASE_DN=dc=quickstack,dc=local
LLDAP_ADMIN_USERNAME=admin
LLDAP_ADMIN_PASSWORD=admin

# ── Backend (Rust) ────────────────────────────────────────────────────────────
# 32-byte base64 AES key. Generate: openssl rand -base64 32
QS_ENCRYPTION_KEY=

# ── Stripe (optional — leave empty to disable online payments) ────────────────
# STRIPE__SECRET_KEY=sk_test_...
# STRIPE__WEBHOOK_SECRET=whsec_...
# STRIPE__CURRENCY=cny

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Public URL of the backend API (as seen by the browser)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
