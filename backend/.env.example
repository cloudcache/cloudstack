# Copy to .env and fill in values before running cargo sqlx prepare or the binary

# MySQL connection string (used by sqlx compile-time checks and at runtime)
DATABASE_URL=mysql://quickstack:password@localhost:3306/quickstack

# 32-byte base64-encoded AES-256-GCM encryption key
# Generate: openssl rand -base64 32
QS_ENCRYPTION_KEY=

# LDAP bind password (from LLDAP admin account)
LDAP_BIND_PASSWORD=

# Logging level
RUST_LOG=info,quickstack=debug
