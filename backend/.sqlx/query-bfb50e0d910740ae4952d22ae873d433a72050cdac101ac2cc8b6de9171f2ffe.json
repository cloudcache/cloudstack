  "query": "SELECT\n             a.id AS app_id,\n             a.name AS app_name,\n             a.status AS app_status,\n             aia.ip_address,\n             aia.pool_id,\n             p.name AS pool_name,\n             p.pool_type,\n             p.gateway,\n             aia.created_at\n           FROM app_ip_allocations aia\n           JOIN apps    a ON a.id    = aia.app_id\n           JOIN ip_pools p ON p.id   = aia.pool_id\n           WHERE a.project_id = ?\n           ORDER BY a.name, p.pool_type",
