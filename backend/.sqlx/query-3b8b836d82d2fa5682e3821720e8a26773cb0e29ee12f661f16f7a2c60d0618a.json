  "query": "SELECT de.id, de.event_type, de.status, de.message, de.created_at,\n                  u.username AS triggered_by_username\n           FROM deployment_events de\n           LEFT JOIN users u ON u.id = de.triggered_by\n           WHERE de.app_id = ?\n           ORDER BY de.created_at DESC\n           LIMIT 100",
