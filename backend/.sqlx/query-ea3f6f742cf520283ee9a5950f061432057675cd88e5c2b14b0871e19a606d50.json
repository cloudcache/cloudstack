  "db_name": "MySQL",
  "query": "SELECT a.id, a.name, a.project_id, p.name AS project_name,\n                      a.status, a.replicas\n               FROM apps a\n               JOIN projects p ON a.project_id = p.id\n               JOIN project_members pm ON pm.project_id = p.id AND pm.user_id = ?\n               ORDER BY p.name, a.name",
