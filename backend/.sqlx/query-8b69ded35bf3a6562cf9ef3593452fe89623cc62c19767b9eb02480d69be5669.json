  "query": "SELECT\n             aia.ip_address,\n             aia.pool_id,\n             p.name        AS pool_name,\n             p.pool_type,\n             p.cidr,\n             p.gateway,\n             aia.created_at\n           FROM app_ip_allocations aia\n           JOIN ip_pools p ON p.id = aia.pool_id\n           WHERE aia.app_id = ?\n           ORDER BY p.pool_type",
