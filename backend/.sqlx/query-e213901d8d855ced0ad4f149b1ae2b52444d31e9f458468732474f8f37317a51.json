  "query": "SELECT p.id, p.name, p.cidr, p.pool_type, p.gateway, p.description, p.is_active, p.created_at,\n                  COUNT(a.id) AS allocated_count\n           FROM ip_pools p\n           LEFT JOIN ip_allocations a ON a.pool_id = p.id\n           GROUP BY p.id ORDER BY p.name",
