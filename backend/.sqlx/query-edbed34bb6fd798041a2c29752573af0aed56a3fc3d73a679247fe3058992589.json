  "query": "SELECT id, snapshot_time, app_count, db_count,\n                  cpu_mcores_used, mem_mb_used, storage_gb_used, cost\n           FROM usage_snapshots\n           WHERE user_id = ?\n             AND (? IS NULL OR snapshot_time >= ?)\n             AND (? IS NULL OR snapshot_time <= ?)\n           ORDER BY snapshot_time DESC\n           LIMIT ? OFFSET ?",
