{
  "slug": "libredesk",
  "name": "Libredesk",
  "icon_url": "https://libredesk.io/apple-touch-icon.png",
  "category": "app",
  "image_repository": "postgres",
  "image_tag": "18-alpine",
  "spec": {
    "appModel": {
      "name": "Libredesk PostgreSQL",
      "appType": "POSTGRES",
      "sourceType": "CONTAINER",
      "containerImageSource": "",
      "replicas": 1,
      "ingressNetworkPolicy": "NAMESPACE_ONLY",
      "egressNetworkPolicy": "DENY_ALL",
      "envVars": "PGDATA=/var/lib/qs-postgres/data\n",
      "useNetworkPolicy": true,
      "healthCheckPeriodSeconds": 15,
      "healthCheckTimeoutSeconds": 5,
      "healthCheckFailureThreshold": 3
    },
    "appDomains": [],
    "appVolumes": [
      {
        "size": 300,
        "containerMountPath": "/var/lib/qs-postgres",
        "accessMode": "ReadWriteOnce",
        "storageClassName": "longhorn",
        "shareWithOtherApps": false
      }
    ],
    "appFileMounts": [],
    "appPorts": [
      {
        "port": 5432
      }
    ]
  },
  "inputs": [
    {
      "key": "POSTGRES_DB",
      "label": "Database Name",
      "value": "libredesk",
      "isEnvVar": true,
      "randomGeneratedIfEmpty": false
    },
    {
      "key": "POSTGRES_USER",
      "label": "Database User",
      "value": "libredesk",
      "isEnvVar": true,
      "randomGeneratedIfEmpty": false
    },
    {
      "key": "POSTGRES_PASSWORD",
      "label": "Database Password",
      "value": "",
      "isEnvVar": true,
      "randomGeneratedIfEmpty": true
    }
  ]
}
