    {
      "key": "MONGO_INITDB_ROOT_USERNAME",
      "label": "Username",
      "value": "mongodbuser",
      "isEnvVar": true,
      "randomGeneratedIfEmpty": false
    },
    {
      "key": "MONGO_INITDB_ROOT_PASSWORD",
      "label": "Password",
      "value": "",
