{
  "slug": "wordpress",
  "name": "WordPress",
  "icon_url": "wordpress.png",
  "category": "app",
  "image_repository": "mariadb",
  "image_tag": "11",
  "spec": {
    "appModel": {
      "name": "MariaDb",
      "appType": "MARIADB",
      "sourceType": "CONTAINER",
      "containerImageSource": "",
      "replicas": 1,
      "ingressNetworkPolicy": "NAMESPACE_ONLY",
      "egressNetworkPolicy": "DENY_ALL",
      "envVars": "MYSQL_DATABASE=wordpress\nMYSQL_USER=wordpress\n",
      "useNetworkPolicy": true,
      "healthCheckPeriodSeconds": 15,
      "healthCheckTimeoutSeconds": 5,
      "healthCheckFailureThreshold": 3
    },
    "appDomains": [],
    "appVolumes": [
      {
        "size": 500,
        "containerMountPath": "/var/lib/mysql",
        "accessMode": "ReadWriteOnce",
        "storageClassName": "longhorn",
        "shareWithOtherApps": false
      }
    ],
    "appFileMounts": [],
    "appPorts": [
      {
        "port": 3306
      }
    ]
  },
  "inputs": [
    {
      "key": "MYSQL_PASSWORD",
      "label": "Database Passwort",
      "value": "",
      "isEnvVar": true,
      "randomGeneratedIfEmpty": true
    },
    {
      "key": "MYSQL_ROOT_PASSWORD",
      "label": "Root Password",
      "value": "",
      "isEnvVar": true,
      "randomGeneratedIfEmpty": true
    }
  ]
}
