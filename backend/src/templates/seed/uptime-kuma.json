{
  "slug": "uptime-kuma",
  "name": "Uptime Kuma",
  "icon_url": "https://raw.githubusercontent.com/louislam/uptime-kuma/master/public/icon.svg",
  "category": "app",
  "image_repository": "louislam/uptime-kuma",
  "image_tag": "latest",
  "spec": {
    "appModel": {
      "name": "Uptime Kuma",
      "appType": "APP",
